{
  "manifest_version": 3,
  "name": "cuongbg — Billing Sync",
  "version": "5.1.0",
  "description": "Auto sync threshold + balance + limit TKQC từ SMIT → cuongbg. Random 20-50p, 1 tab nhanh gọn.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "cuongbg Billing Sync"
  },
  "permissions": [
    "storage",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "https://linhdangbai-2odf.vercel.app/*",
    "https://adscheck.smit.vn/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://adscheck.smit.vn/*"
      ],
      "js": ["content-smit.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
