# Database — Supabase Postgres connection string
# Lấy ở: Supabase Dashboard → Settings → Database → Connection string → URI
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# JWT secret cho cookie auth — bắt buộc, tối thiểu 16 ký tự
# Sinh chuỗi random: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="thay-bang-chuoi-random-toi-thieu-32-ky-tu"

# URL public của app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Secret cho cron sync-posts (tự sinh chuỗi random)
CRON_SECRET="thay-bang-chuoi-random-cron"

# Anthropic API key cho AI analyze video frames (Phase 2 — V1 semi-auto).
# Lấy ở: https://console.anthropic.com → Settings → API Keys
# Optional: nếu không set, feature "Phân tích video AI" sẽ disabled (vẫn search keyword tay được).
ANTHROPIC_API_KEY=""

# RapidAPI Facebook Video Downloader — cho feature "🔗 FB Reel URL" (paste URL → server tự download).
# 1. Sign up rapidapi.com (free)
# 2. Search "Facebook Video Downloader" → subscribe service (Basic free tier ~50 calls/tháng để test)
# 3. Copy "X-RapidAPI-Key" → set RAPIDAPI_KEY
# 4. Copy hostname service → set RAPIDAPI_HOST (vd "facebook-video-downloader9.p.rapidapi.com")
# 5. Copy path endpoint → set RAPIDAPI_PATH (vd "/api/v1/videos/download")
# Optional: không set → mode "🔗 FB Reel URL" disabled, các mode khác vẫn dùng được.
RAPIDAPI_KEY=""
RAPIDAPI_HOST="facebook-video-downloader9.p.rapidapi.com"
RAPIDAPI_PATH="/api/v1/videos/download"
